# ─── OpenUni — Local Dev Environment ─────────────────────────────────────────
# Copy this file to .env and fill in any values you want to override.
#   cp .env.example .env
#
# The defaults below are intentionally insecure "dev-only" values; never use
# them in production.

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=openuni
POSTGRES_PASSWORD=openuni
POSTGRES_DB=openuni
# Full DSN consumed by the API (hostname = docker-compose service name)
DATABASE_URL=postgresql+psycopg://openuni:openuni@postgres:5432/openuni

# ─── Qdrant ───────────────────────────────────────────────────────────────────
QDRANT_URL=http://qdrant:6333

# ─── API ──────────────────────────────────────────────────────────────────────
API_PORT=8000
# Set to "development" or "production"
ENVIRONMENT=development

# ─── LLM Provider (answer generation) ───────────────────────────────────────
# Controls which backend generate_answer() uses. Two options:
#
#   openai  — OpenAI Chat Completions API (default).  Requires OPENAI_API_KEY.
#   ollama  — Local Ollama instance (free, offline).  Requires OLLAMA_URL and
#             a running Ollama server with the desired model pulled.
#
# To switch to Ollama: set LLM_PROVIDER=ollama (and leave OPENAI_API_KEY empty).
LLM_PROVIDER=openai

# ─── OpenAI (used when LLM_PROVIDER=openai) ──────────────────────────────────
# Required at runtime for the generation step.  Never commit real keys.
OPENAI_API_KEY=sk-replace-me
# Optional: override the default model (gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# ─── Ollama (used when LLM_PROVIDER=ollama) ───────────────────────────────────
# OLLAMA_URL is also used by the ingestion pipeline for embeddings.
OLLAMA_URL=http://ollama:11434
# Optional: override the generation model (default: llama3.1)
# OLLAMA_MODEL=llama3.1
# Optional: override the embedding model used by RAG retrieval (default: nomic-embed-text)
# EMBEDDING_MODEL=nomic-embed-text
