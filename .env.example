# ─── OpenUni — Local Dev Environment ─────────────────────────────────────────
# Copy this file to .env and fill in any values you want to override.
#   cp .env.example .env
#
# The defaults below are intentionally insecure "dev-only" values; never use
# them in production.

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=openuni
POSTGRES_PASSWORD=openuni
POSTGRES_DB=openuni
# Full DSN consumed by the API (hostname = docker-compose service name)
DATABASE_URL=postgresql+psycopg://openuni:openuni@postgres:5432/openuni

# ─── Qdrant ───────────────────────────────────────────────────────────────────
QDRANT_URL=http://qdrant:6333

# ─── API ──────────────────────────────────────────────────────────────────────
API_PORT=8000
# Set to "development" or "production"
ENVIRONMENT=development

# ─── OpenAI (answer generation) ───────────────────────────────────────────────
# Required at runtime for the generation step.  Never commit real keys.
OPENAI_API_KEY=sk-replace-me
# Optional: override the default model (gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini
